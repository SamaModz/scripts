#!/usr/bin/env bash

# ---------------- COLORS ----------------
RED="\e[0;31m"
GREEN="\e[0;32m"
YELLOW="\e[0;33m"
BLUE="\e[0;34m"
PINK="\e[0;35m"
CYAN="\e[0;36m"
WHITE="\e[0;37m"
NONE="\e[0m"

# ---------------- FUNÇÕES ----------------

# remove ANSI
strip_ansi() {
  sed -r 's/\x1B\[[0-9;]*[mK]//g'
}

# largura visual real (Unicode + Nerd Fonts)
vlen() {
  if command -v perl >/dev/null 2>&1 && perl -MUnicode::GCString -e 1 2>/dev/null; then
    echo -e "$1" | strip_ansi | perl -CS -MUnicode::GCString -ne '
    my $g = Unicode::GCString->new($_);
    print $g->columns;
    '
  else
    echo -e "$1" | strip_ansi | awk '{ print length }'
  fi
}

# corta mantendo largura visual
vcut() {
  local text="$1"
  local max="$2"

  if command -v perl >/dev/null 2>&1 && perl -MUnicode::GCString -e 1 2>/dev/null; then
    echo -e "$text" | perl -CS -MUnicode::GCString -ne "
    my \$g = Unicode::GCString->new(\$_);
    print \$g->substr(0, $max);
    "
  else
    echo -e "$text" | cut -c1-"$max"
  fi
}

# ---------------- INFO ----------------

USER=$(whoami)
HOST=$(hostname)
DISTRO="$(uname -o) $(getprop ro.build.version.release 2>/dev/null)"
KERNEL="$(uname -r | cut -d- -f1)"
SHELL_NAME=$(basename "$SHELL")
DATE=$(date +%d/%m/%Y)
UPTIME=$(uptime -p | sed 's/up //' | awk '{for(i=1;i<=NF;i++) if($i~/day/) h+=$(i-1)*24; else if($i~/hour/) h+=$(i-1); else if($i~/min/) m=$(i-1)} END{printf "%dh%02dmin\n", h, m}')
MEMORY=$(free -h --si | awk '/^Mem:/ {print $3 "/" $2}')

if command -v pacman >/dev/null 2>&1; then
  PACKAGES=$(pacman -Qq | wc -l)
elif command -v dpkg >/dev/null 2>&1; then
  PACKAGES=$(dpkg -l | grep -c '^ii')
elif command -v rpm >/dev/null 2>&1; then
  PACKAGES=$(rpm -qa | wc -l)
elif command -v apk >/dev/null 2>&1; then
  PACKAGES=$(apk info | wc -l)
else
  PACKAGES="?"
fi



# ---------------- LINHAS ----------------

if1="$WHITE$NONE ${RED}${USER}${NONE}"
if2="$WHITE󰇄$NONE ${YELLOW}${HOST}${NONE}"
if3="$WHITE󰻀$NONE ${GREEN}${DISTRO}${NONE}"
if4="$WHITE󰓼$NONE ${CYAN}${KERNEL}${NONE}"
if5="$WHITE󱑎$NONE ${BLUE}${UPTIME}${NONE}"
if6="$WHITE󱆃$NONE ${PINK}${SHELL_NAME}${NONE}"
if7="$WHITE󰏗$NONE ${RED}${PACKAGES}${NONE}"
if8="$WHITE󰍛$NONE ${YELLOW}${MEMORY}${NONE}"
if9="$WHITE󱦂$NONE ${GREEN}${MYIP}${NONE}"
if10="$WHITE󱦂$NONE ${GREEN}${DATE}${NONE}"
lines=(
  # "     $if10       "
  "                      "
  " $RED██  ██  ██  $if1 "
  " $RED██  ██  ██  $if2 "
  " $RED██████████  $if3 "
  " $RED    ██      $if4 "
  " $RED    ██  ██  $if5 "
  " $RED██████████  $if6 "
  " $RED██  ██      $if7 "
  " $RED    ██      $if8 "
  # " $RED    ██      $if9 "
  "                      "
  "      $RED $GREEN $YELLOW $BLUE $CYAN $PINK $WHITE "
)

# ---------------- CALCULA LARGURA ----------------

declare -A cache
max=0

for l in "${lines[@]}"; do
  len=$(vlen "$l")
  cache["$l"]=$len
  (( len > max )) && max=$len
done

# ---------------- DESENHA CAIXA ----------------
tput rmam
# topo
printf "╭"
printf "─%.0s" $(seq 1 $((max + 2)))
printf "╮\n"

# conteúdo
for l in "${lines[@]}"; do
  len=${cache["$l"]}

  if (( len > max )); then
    l="$(vcut "$l" "$max")"
    len=$(vlen "$l")
  fi

  pad=$((max - len))
  printf "│ %b" "$l"
  printf "%*s │\n" "$pad" ""
done

# base
printf "╰"
printf "─%.0s" $(seq 1 $((max + 2)))
printf "╯\n"

tput smam
